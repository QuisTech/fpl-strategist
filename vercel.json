{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/fpl/(.*)",
      "destination": "/api/fpl.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/fpl.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/fpl.ts": {
      "maxDuration": 30
    }
  }
}
